{
	"$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@sveltejs/opencode",
    "@plannotator/opencode@latest",
    "opencode-lmstudio@latest"
  ],
  "mcp": {
    "backlog": {
      "type": "local",
      "command": [
        "backlog",
        "mcp",
        "start"
      ]
    }   
  },
  "provider": {
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "My LM Studio",
      "options": {
        "baseURL": "http://172.21.176.1:1234/v1"
      }
    }
  }
}
