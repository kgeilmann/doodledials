{
	"name": "doodledials",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "playwright install && svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright test",
		"build:sea:blob": "node --experimental-sea-config server/sea-config.json",
		"build:sea:linux": "cp $(which node) doodledials-server && npx postject doodledials-server NODE_SEA_BLOB server/sea.blob --sentinel-fuse NODE_SEA_FUSE_fce680ab2cc467b6e072b8b5df1996b2",
		"build:sea:win": "echo 'Requires Windows node.exe. See server/README.md'",
		"build:sea": "pnpm build && pnpm build:sea:blob && pnpm build:sea:linux"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.3",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.58.2",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@types/node": "^24",
		"@types/three": "^0.184.1",
		"@vitest/browser-playwright": "^4.1.0",
		"autoprefixer": "^10.4.20",
		"eslint": "^10.0.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.15.2",
		"globals": "^17.4.0",
		"jsdom": "^29.1.1",
		"playwright": "^1.58.2",
		"postcss": "^8.4.49",
		"postject": "1.0.0-alpha.6",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.2.2",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.0",
		"vite": "^7.3.1",
		"vitest": "^4.1.0",
		"vitest-browser-svelte": "^2.0.2"
	},
	"dependencies": {
		"@svgdotjs/svg.js": "^3.2.5",
		"@tailwindcss/postcss": "^4.2.2",
		"potrace-plus": "0.1.3",
		"svg-path-properties": "^2.0.2",
		"three": "^0.184.0"
	}
}
